# ============================================================
# Variables de entorno para despliegue manual via SSH a IIS
#
# Uso:
#   cp .env.deploy.example .env.deploy
#   # Editar .env.deploy con tus valores reales
#   ./deploy_iis.sh
#
# Requisitos en Mac:
#   brew install hudochenkov/sshpass/sshpass
#   dotnet SDK 8.0+
#   node 20+
# ============================================================

# --- Servidor ---
DEPLOY_SERVER=TU_IP_O_DOMINIO
DEPLOY_SSH_PORT=22

# --- IIS ---
DEPLOY_SITE=NombreAppPool
DEPLOY_PATH=C:/inetpub/wwwroot/TuSitio

# --- Credenciales SSH ---
# Este archivo se carga con `source` (es bash real): si el password tiene
# caracteres especiales de shell ( ) * ? ! @ $ etc, va entre comillas simples
# para que no rompa la sintaxis ni dispare expansion de glob.
DEPLOY_USER=TU_USUARIO
DEPLOY_PASSWORD='TU_PASSWORD'

# --- Proyecto ---
DEPLOY_PROJECT=carpetaDeTuApp/TuSitio.csproj
# DEPLOY_CLIENT_DIR=TuSitio.Frontend   # opcional — omitir si no hay app cliente

# --- Archivos a preservar en el servidor (no se sobreescriben al desplegar) ---
DEPLOY_PRESERVE=appsettings.Production.json,logs

# --- URL pública (opcional, para verificar deploy) ---
DEPLOY_URL=https://midominio.com
